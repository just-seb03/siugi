Options -Indexes -MultiViews
DirectoryIndex public/index.php

RewriteEngine On
RewriteBase /SIUGI/


RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]


RewriteCond %{DOCUMENT_ROOT}/SIUGI/src/$1.php -f
RewriteRule ^src/(.*)$ src/$1.php [L]


RewriteCond %{DOCUMENT_ROOT}/SIUGI/public/$1.php -f
RewriteRule ^(.*)$ public/$1.php [L]


RewriteCond %{DOCUMENT_ROOT}/SIUGI/views/$1.php -f
RewriteRule ^(.*)$ views/$1.php [L]


RewriteCond %{DOCUMENT_ROOT}/SIUGI/views/bienes/$1.php -f
RewriteRule ^(.*)$ views/bienes/$1.php [L]


RewriteCond %{DOCUMENT_ROOT}/SIUGI/views/usuarios/$1.php -f
RewriteRule ^(.*)$ views/usuarios/$1.php [L]


RewriteCond %{DOCUMENT_ROOT}/SIUGI/views/mantenedores/$1.php -f
RewriteRule ^(.*)$ views/mantenedores/$1.php [L]